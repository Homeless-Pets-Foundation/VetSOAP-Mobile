# Captivet Mobile - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

EXPO_PUBLIC_API_URL=https://your-api-url.example.com
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
EXPO_PUBLIC_R2_BUCKET_HOSTNAME=your-account-id.r2.cloudflarestorage.com

# ── Monitoring (all optional — empty = SDK silently disabled) ──
# Sentry DSN for the mobile React Native project. Get it from
# Sentry → Project → Settings → Client Keys. Create a SEPARATE project
# from the server — don't reuse the server DSN, or release/source-map
# tracking will collide with the API's.
EXPO_PUBLIC_SENTRY_DSN=

# PostHog project key (starts with `phc_`). Create a separate project from
# the server for the same reason. Host defaults to US cloud; change if using
# EU cloud or a self-hosted instance.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional — flip to "true" to enable Sentry in dev builds (off by default so
# test crashes don't pollute the production project's error feed).
# EXPO_PUBLIC_SENTRY_ENABLE_IN_DEV=true
